# =====================================================
# elt-pipeline-aws-medallion — env example
# Copie para .env e ajuste valores. NUNCA commitar .env
# =====================================================

# ---------- Airflow ----------
# UID do host (Linux/Mac: `id -u`; Windows/WSL: 50000 default)
AIRFLOW_UID=50000
# Porta do webserver
AIRFLOW_WEBSERVER_PORT=8080
# Credenciais admin iniciais (apenas dev local)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# ---------- AWS (Sprint 2+) ----------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Profile alternativo (preferir a usar keys hardcoded em dev)
# AWS_PROFILE=elt-pipeline-dev

# ---------- Buckets S3 (Sprint 2+) ----------
S3_BUCKET_BRONZE=elt-pipeline-bronze-dev
S3_BUCKET_SILVER=elt-pipeline-silver-dev
S3_BUCKET_GOLD=elt-pipeline-gold-dev
S3_BUCKET_PLATINUM=elt-pipeline-platinum-dev
S3_BUCKET_ATHENA_RESULTS=elt-pipeline-athena-results-dev

# ---------- Athena (Sprint 4+) ----------
ATHENA_WORKGROUP=elt-pipeline-dev
ATHENA_DATABASE=gold

# ---------- Data Generator ----------
DATA_GENERATOR_OUTPUT=./data-generator/output
DATA_GENERATOR_SEED=42

# ---------- Slack (Sprint 6+) ----------
SLACK_WEBHOOK_URL=
